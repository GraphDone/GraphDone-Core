# Parse command line arguments
REMAINING_ARGS=()
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            show_help
            exit 0
            ;;
        -q|--quiet)
            QUIET=true
            SKIP_BANNER=true
            shift
            ;;
        --no-banner)
            SKIP_BANNER=true
            shift
            ;;
        dev|quick|clean|setup|test|build|deploy|stop|remove|status|vm)
            COMMAND="$1"
            shift
            # Capture remaining arguments for the command
            REMAINING_ARGS=("$@")
            break
            ;;
        *)
            echo -e "${RED}❌ Unknown option or command: $1${NC}"
            echo "Use './start --help' for usage information."
            exit 1
            ;;
    esac
done

